MEMORY_ROOT = Path(os.getenv("WALNUT_MEMORY_DIR", str(HOME / "walnut-memory")))
NOTES_DIR = MEMORY_ROOT / "daily"
MUSIC_LINK = HOME / "Music" / "WalnutMusic"
CMUS_PLAYLIST = HOME / ".config" / "cmus" / "walnut-library.pls"
MUSIC_DIR_CANDIDATES = [HOME / "music-library", Path("/root/music-library")]
AIRPODS_MAC = "34:0E:22:C0:C7:CC"
BROWSER_URL = "https://lite.duckduckgo.com/lite/"
MUSIC_EXTENSIONS = {".mp3", ".ogg", ".oga", ".flac", ".wav"}


def run(cmd: list[str], check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, check=check)


def stream(cmd: list[str]) -> int:
    try:
        return subprocess.call(cmd)
    except FileNotFoundError:
        print(f"missing command: {cmd[0]}")
        return 127


def exists(cmd: str) -> bool:
    return shutil.which(cmd) is not None


def root_cmd(cmd: list[str]) -> list[str]:
    if os.geteuid() == 0:
        return cmd
    if exists("sudo"):
        return ["sudo", "-n", *cmd]
    return cmd


def require_root(action: str) -> bool:
    if os.geteuid() == 0:
        return True
    print(f"{action} needs administrator permission.")
    print(f"Run: sudo walnut {action}")
    return False


def section(title: str) -> None:
    print(f"\n== {title} ==")


def pause(prompt: str = "Press Enter...") -> None:
    input(f"\n{prompt}")


def clear_screen() -> None:
    os.system("clear")


def one_line(cmd: list[str], fallback: str = "-") -> str:
    try:
        out = run(cmd).stdout.strip()
        return out if out else fallback
    except Exception:
        return fallback


def music_dir() -> Path:
    for path in MUSIC_DIR_CANDIDATES:
        if path.exists():
            return path
    return MUSIC_DIR_CANDIDATES[0]


def prepare_music() -> tuple[Path, Path, Path]:
    current_music_dir = music_dir()
    MUSIC_LINK.parent.mkdir(parents=True, exist_ok=True)
    CMUS_PLAYLIST.parent.mkdir(parents=True, exist_ok=True)

    if current_music_dir.exists():
        try:
            if MUSIC_LINK.is_symlink() or MUSIC_LINK.is_file():
                MUSIC_LINK.unlink()
            if not MUSIC_LINK.exists():
                MUSIC_LINK.symlink_to(current_music_dir, target_is_directory=True)
        except OSError:
            pass

        tracks = sorted(
            str(path)
            for path in current_music_dir.rglob("*")
            if path.is_file() and path.suffix.lower() in MUSIC_EXTENSIONS
        )
        CMUS_PLAYLIST.write_text(
            "\n".join(tracks) + ("\n" if tracks else ""),
            encoding="utf-8",
        )

    return current_music_dir, MUSIC_LINK, CMUS_PLAYLIST


def launch_cmus() -> int:
    current_music_dir, current_music_link, current_playlist = prepare_music()
    clear_screen()
    print("cmus quick keys:")
    print("  2        library view")
    print("  3        playlist view")
    print("  5        file browser view")
    print("  Enter    add/play selected file")
    print("  c        pause/resume")
    print("  b        next track")
    print("  z        previous track")
    print("  + / -    volume")
    print("  q        quit")
    print()
    print("Music folder:")
    print(f"  {current_music_link} -> {current_music_dir}")
    print("\nLaunching cmus with WalnutMusic loaded. Use q to quit cmus.\n")

    if current_playlist.exists() and current_playlist.stat().st_size > 0:
        return stream(["cmus", str(current_playlist)])
    if current_music_link.exists():
        return stream(["cmus", str(current_music_link)])
    return stream(["cmus"])


def launch_matrix() -> int:
    clear_screen()
    print("cmatrix quick keys:")
    print("  Ctrl+C    quit and return to Walnut")
    print()
    print("Recommended options:")
    print("  -a        asynchronous scroll")
    print("  -b        bold characters")
    print("  ASCII mode avoids missing-glyph squares on the small framebuffer screen")
    print("\nLaunching cmatrix. Press Ctrl+C to quit.\n")
    return stream(["cmatrix", "-ab"])


def launch_browser() -> int:
    if exists("w3m"):
        return stream(["w3m", BROWSER_URL])
    if exists("lynx"):
        return stream(["lynx", BROWSER_URL])
    print("No terminal browser found. Install w3m or lynx.")
    return 1


def launch_monitor() -> int:
    size = shutil.get_terminal_size(fallback=(80, 24))
    if size.columns >= 100 and exists("btop"):
        return stream(["btop"])
    if exists("htop"):
        return stream(["htop"])
    if exists("btop"):
        return stream(["btop"])
    print("No process monitor found. Install htop or btop.")
    return 1


def launch_clock() -> int:
    return stream(["tty-clock", "-c", "-s"])


