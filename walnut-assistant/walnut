#!/usr/bin/env python3
"""Walnut Assistant V0: command hub for a headless WalnutPi AI terminal."""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
from datetime import datetime
from pathlib import Path


PROJECT_ROOT = Path("/home/pi/projects/WalnutPi")
HOME = Path.home()
MEMORY_ROOT = Path(os.getenv("WALNUT_MEMORY_DIR", str(HOME / "walnut-memory")))
NOTES_DIR = MEMORY_ROOT / "daily"
MUSIC_LINK = HOME / "Music" / "WalnutMusic"
CMUS_PLAYLIST = HOME / ".config" / "cmus" / "walnut-library.pls"
MUSIC_DIR_CANDIDATES = [HOME / "music-library", Path("/root/music-library")]
MUSIC_CLI = HOME / "music"
AIRPODS_MAC = "34:0E:22:C0:C7:CC"
BROWSER_URL = "https://lite.duckduckgo.com/lite/"
MUSIC_EXTENSIONS = {".mp3", ".ogg", ".oga", ".flac", ".wav"}


def run(cmd: list[str], check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, check=check)


def stream(cmd: list[str]) -> int:
    try:
        return subprocess.call(cmd)
    except FileNotFoundError:
        print(f"missing command: {cmd[0]}")
        return 127


def exists(cmd: str) -> bool:
    return shutil.which(cmd) is not None


def root_cmd(cmd: list[str]) -> list[str]:
    if os.geteuid() == 0:
        return cmd
    if exists("sudo"):
        return ["sudo", "-n", *cmd]
    return cmd


def require_root(action: str) -> bool:
    if os.geteuid() == 0:
        return True
    print(f"{action} needs administrator permission.")
    print(f"Run: sudo walnut {action}")
    return False


def section(title: str) -> None:
    print(f"\n== {title} ==")


def pause(prompt: str = "Press Enter...") -> None:
    input(f"\n{prompt}")


def clear_screen() -> None:
    os.system("clear")


def one_line(cmd: list[str], fallback: str = "-") -> str:
    try:
        out = run(cmd).stdout.strip()
        return out if out else fallback
    except Exception:
        return fallback


def music_dir() -> Path:
    for path in MUSIC_DIR_CANDIDATES:
        if path.exists():
            return path
    return MUSIC_DIR_CANDIDATES[0]


def prepare_music() -> tuple[Path, Path, Path]:
    current_music_dir = music_dir()
    MUSIC_LINK.parent.mkdir(parents=True, exist_ok=True)
    CMUS_PLAYLIST.parent.mkdir(parents=True, exist_ok=True)

    if current_music_dir.exists():
        try:
            if MUSIC_LINK.is_symlink() or MUSIC_LINK.is_file():
                MUSIC_LINK.unlink()
            if not MUSIC_LINK.exists():
                MUSIC_LINK.symlink_to(current_music_dir, target_is_directory=True)
        except OSError:
            pass

        tracks = sorted(
            str(path)
            for path in current_music_dir.rglob("*")
            if path.is_file() and path.suffix.lower() in MUSIC_EXTENSIONS
        )
        CMUS_PLAYLIST.write_text(
            "\n".join(tracks) + ("\n" if tracks else ""),
            encoding="utf-8",
        )

    return current_music_dir, MUSIC_LINK, CMUS_PLAYLIST


def launch_cmus() -> int:
    current_music_dir, current_music_link, current_playlist = prepare_music()
    clear_screen()
    print("cmus quick keys:")
    print("  2        library view")
    print("  3        playlist view")
    print("  5        file browser view")
    print("  Enter    add/play selected file")
    print("  c        pause/resume")
    print("  b        next track")
    print("  z        previous track")
    print("  + / -    volume")
    print("  q        quit")
    print()
    print("Music folder:")
    print(f"  {current_music_link} -> {current_music_dir}")
    print("\nLaunching cmus with WalnutMusic loaded. Use q to quit cmus.\n")

    if current_playlist.exists() and current_playlist.stat().st_size > 0:
        return stream(["cmus", str(current_playlist)])
    if current_music_link.exists():
        return stream(["cmus", str(current_music_link)])
    return stream(["cmus"])


def list_music(_: argparse.Namespace | None = None) -> int:
    current_music_dir, current_music_link, _ = prepare_music()
    clear_screen()
    print(f"Music folder: {current_music_link}\n")
    if MUSIC_CLI.exists() and os.access(MUSIC_CLI, os.X_OK):
        subprocess.call([str(MUSIC_CLI), "list"])
    else:
        for path in sorted(current_music_dir.rglob("*")) if current_music_dir.exists() else []:
            if path.is_file():
                print(path)
    pause()
    return 0


def launch_matrix() -> int:
    clear_screen()
    print("cmatrix quick keys:")
    print("  Ctrl+C    quit and return to Walnut")
    print()
    print("Recommended options:")
    print("  -a        asynchronous scroll")
    print("  -b        bold characters")
    print("  -u 2      Unicode character set")
    print("\nLaunching cmatrix. Press Ctrl+C to quit.\n")
    return stream(["cmatrix", "-ab", "-u", "2"])


def open_cn(_: argparse.Namespace | None = None) -> int:
    if exists("walnut-cn"):
        return stream(["walnut-cn"])
    print("walnut-cn is missing")
    return 1


def open_video(args: argparse.Namespace | None = None) -> int:
    mode = getattr(args, "mode", "color")
    if exists("walnut-ai-video-demo-play"):
        return stream(["walnut-ai-video-demo-play", mode])
    print("walnut-ai-video-demo-play is missing")
    return 1


def status(_: argparse.Namespace | None = None) -> int:
    section("WalnutPi")
    print(one_line(["hostnamectl"], "hostnamectl unavailable"))

    section("Network")
    print(one_line(["ip", "-br", "addr"]))
    print(one_line(["ip", "route", "show", "default"]))
    if exists("nmcli"):
        print(one_line(["nmcli", "-t", "-f", "ACTIVE,SSID,SIGNAL", "dev", "wifi"]))

    section("Storage")
    print(one_line(["df", "-h", "/", "/boot"]))
    print(one_line(["findmnt", "-n", "-o", "SOURCE,FSTYPE,OPTIONS,TARGET", "/"]))

    section("Memory")
    print(one_line(["free", "-h"]))

    section("Services")
    for service in ["ssh", "NetworkManager", "docker", "frpc", "voice-keyboard-walnutpi", "bluealsa-aplay", "bluetooth"]:
        state = one_line(root_cmd(["systemctl", "is-active", service]), "unknown")
        enabled = one_line(root_cmd(["systemctl", "is-enabled", service]), "unknown")
        print(f"{service:26} active={state:10} enabled={enabled}")

    section("Docker")
    if exists("docker"):
        if os.geteuid() == 0:
            print(one_line(["docker", "ps", "--format", "table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}"]))
        else:
            print("Docker is installed. Run `sudo walnut status` to inspect containers.")
    else:
        print("docker not installed")

    section("Audio")
    print(one_line(["bluetoothctl", "info", AIRPODS_MAC], "AirPods not known"))
    return 0


def clean(_: argparse.Namespace | None = None) -> int:
    if not require_root("clean"):
        return 1
    print("Walnut clean keeps projects, music, Codex config, GitHub login, Docker data, and Uptime Kuma data.")
    print("Cleaning apt cache, old journals, and old temp files...")
    commands = [
        root_cmd(["apt-get", "clean"]),
        root_cmd(["journalctl", "--vacuum-size=50M"]),
        ["find", "/tmp", "-mindepth", "1", "-maxdepth", "1", "-mtime", "+1", "-delete"],
        ["find", "/var/tmp", "-mindepth", "1", "-maxdepth", "1", "-mtime", "+7", "-delete"],
    ]
    for cmd in commands:
        print(f"$ {' '.join(cmd)}")
        subprocess.call(cmd)
    section("After Clean")
    print(one_line(["df", "-h", "/"]))
    return 0


def fix_audio(_: argparse.Namespace | None = None) -> int:
    if not require_root("fix-audio"):
        return 1
    print("Switching Bluetooth audio back to PulseAudio A2DP playback mode.")
    subprocess.call(root_cmd(["systemctl", "disable", "--now", "bluealsa-aplay"]))
    subprocess.call(root_cmd(["systemctl", "disable", "--now", "bluealsa"]))
    subprocess.call(root_cmd(["pkill", "-f", "^/usr/bin/bluealsa-aplay"]))
    if exists("vk-airpods-audio"):
        return stream(["vk-airpods-audio"])
    print("vk-airpods-audio is missing")
    return 1


def projects(_: argparse.Namespace | None = None) -> int:
    section("Projects")
    for path in [PROJECT_ROOT, Path("/home/pi/projects/voice-keyboard"), Path("/opt/walnut-ai"), Path("/opt/uptime-kuma"), Path("/opt/frp")]:
        if path.exists():
            print(path)
    section("Git")
    if PROJECT_ROOT.exists():
        subprocess.call(["git", "config", "--global", "--add", "safe.directory", str(PROJECT_ROOT)])
        subprocess.call(["git", "-C", str(PROJECT_ROOT), "status", "--short"])
    return 0


def sync(_: argparse.Namespace | None = None) -> int:
    if not PROJECT_ROOT.exists():
        print(f"missing project root: {PROJECT_ROOT}")
        return 1
    print("GitHub sync for WalnutPi repository.")
    subprocess.call(["git", "-C", str(PROJECT_ROOT), "status", "--short"])
    print("\nNote: if git push hangs on this board, use Codex to sync via gh api as a fallback.")
    return subprocess.call(["git", "-C", str(PROJECT_ROOT), "push", "origin", "main"])


def note(args: argparse.Namespace) -> int:
    NOTES_DIR.mkdir(parents=True, exist_ok=True)
    text = " ".join(args.text).strip()
    if not text:
        print("Usage: walnut note your text")
        return 2
    path = NOTES_DIR / f"{datetime.now().date().isoformat()}.md"
    with path.open("a", encoding="utf-8") as f:
        f.write(f"\n- {datetime.now().strftime('%H:%M')} {text}\n")
    print(f"saved: {path}")
    return 0


def today(_: argparse.Namespace | None = None) -> int:
    path = NOTES_DIR / f"{datetime.now().date().isoformat()}.md"
    if path.exists():
        print(path.read_text(encoding="utf-8"))
    else:
        print("No notes today.")
    return 0


def open_ai(_: argparse.Namespace | None = None) -> int:
    if exists("walnut-ai"):
        return stream(["walnut-ai"])
