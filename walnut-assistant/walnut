def menu(_: argparse.Namespace | None = None) -> int:
    while True:
        clear_screen()
        print("Walnut Assistant V0")
        print()
        print("  1. AI Chat")
        print("  2. Status")
        print("  3. Notes: add")
        print("  4. Notes: today")
        print("  5. Tools / Fun")
        print("  6. Chinese Console")
        print("  7. ASCII Video Demo")
        print("  8. Fix AirPods audio")
        print("  9. Projects")
        print(" 10. Clean")
        print(" 11. Voice")
        print()
        print("  q. Quit")
