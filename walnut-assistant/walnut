        if choice == "1":
            open_ai(None)
        elif choice == "2":
            status(None)
            input("\nPress Enter...")
        elif choice == "3":
            text = input("Note> ").strip()
            if text:
                note(argparse.Namespace(text=[text]))
                input("\nPress Enter...")
        elif choice == "4":
            today(None)
            pause()
        elif choice == "5":
            tools_menu(None)
        elif choice == "6":
            open_cn(None)
        elif choice == "7":
            open_video(argparse.Namespace(mode="color"))
        elif choice == "8":
            fix_audio(None)
            pause()
        elif choice == "9":
            projects(None)
            pause()
        elif choice == "10":
            clean(None)
            pause()
        elif choice == "11":
            voice(None)
        elif choice in {"q", "quit", "exit"}:
            return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Walnut Assistant V0")
    sub = parser.add_subparsers(dest="cmd")

    commands = {
        "status": status,
        "clean": clean,
        "fix-audio": fix_audio,
        "projects": projects,
        "sync": sync,
        "ai": open_ai,
        "cn": open_cn,
        "video": open_video,
        "toys": tools_menu,
        "fun": fun,
        "voice": voice,
        "today": today,
        "music-list": list_music,
    }
    for name, func in commands.items():
        p = sub.add_parser(name)
        if name == "video":
            p.add_argument("mode", nargs="?", choices=["color", "gray", "still-color", "still-gray"], default="color")
        p.set_defaults(func=func)

    p_note = sub.add_parser("note")
    p_note.add_argument("text", nargs="*")
    p_note.set_defaults(func=note)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if not args.cmd:
        return menu(args)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
