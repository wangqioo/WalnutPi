def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Walnut Home")
    sub = parser.add_subparsers(dest="cmd")

    commands = {
        "status": status,
        "ai": open_ai,
        "notes": notes_menu,
        "play": play_menu,
        "console": console_menu,
        "maintenance": maintenance_menu,
        "video": open_video,
        "voice": voice,
        "today": today,
    }
    for name, func in commands.items():
        p = sub.add_parser(name)
        if name == "video":
            p.add_argument("mode", nargs="?", choices=["color", "gray", "still-color", "still-gray"], default="color")
        p.set_defaults(func=func)

    p_note = sub.add_parser("note")
    p_note.add_argument("text", nargs="*")
    p_note.set_defaults(func=note)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if not args.cmd:
        return menu(args)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
